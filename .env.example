# snapah pow - variables de entorno
# Copia este archivo como .env y ajusta los valores

# Seguridad - CAMBIAR EN PRODUCCION
SNAPAH_ADMIN_PASSWORD=admin123
JWT_SECRET=change-me-use-openssl-rand-hex-32
SNAPAH_TOKEN=change-me-agent-token

# Base de datos
DATABASE_URL=data/snapah.db
# Para PostgreSQL:
# DATABASE_URL=postgres://user:password@localhost:5432/snapah

# Alertas por email (opcional)
ALERT_EMAIL_TO=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=snapah@tudominio.com

# Alertas por webhook Slack/Discord (opcional)
ALERT_WEBHOOK_URL=
